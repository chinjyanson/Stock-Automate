# =============================================================================
# Trading Platform — example environment
#
# Copy to `.env` and fill in. `.env` is gitignored and must never be committed.
# Nothing in this file reaches the browser: only variables prefixed with
# NEXT_PUBLIC_ are exposed client-side, and no credential uses that prefix.
# =============================================================================

# -----------------------------------------------------------------------------
# Core infrastructure
# -----------------------------------------------------------------------------
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_dev_password_change_me
POSTGRES_DB=trading_platform

# Host-side ports deliberately avoid the defaults (5432/6379) so this stack can
# run alongside another local Postgres or Redis without a port clash. The
# container-side ports are unchanged, so service-to-service URLs inside the
# compose network still use 5432/6379 — see docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
REDIS_PORT=6380

# These URLs are what you connect with from the HOST (running tests, psql, the
# API outside Docker). docker-compose.yml overrides them for in-network use.
DATABASE_URL=postgresql+asyncpg://trading:trading_dev_password_change_me@localhost:5433/trading_platform

REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated list of origins permitted to call the API with credentials.
CORS_ALLOW_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Security
#
# SESSION_SECRET signs session cookies.
# SECRETS_ENCRYPTION_KEY encrypts broker/provider credentials at rest (§17).
# Generate both with:  openssl rand -base64 32
# Rotating SECRETS_ENCRYPTION_KEY makes existing stored credentials unreadable;
# re-enter them after rotation.
# -----------------------------------------------------------------------------
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
SECRETS_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
SESSION_TTL_SECONDS=86400
SESSION_COOKIE_NAME=trading_session
SESSION_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Trading 212 — DEMO credentials
#
# Generate at: Trading 212 app → Settings → API (Beta). Use a DEMO/practice
# account key here. Leaving this blank is supported: the platform falls back to
# a deterministic mock broker so the full paper workflow runs with no
# credentials at all (§23).
# -----------------------------------------------------------------------------
TRADING212_DEMO_API_KEY=
TRADING212_DEMO_BASE_URL=https://demo.trading212.com/api/v0

# -----------------------------------------------------------------------------
# Trading 212 — LIVE credentials
#
# DANGER: a key here can place real-money orders. Live trading additionally
# requires LIVE_TRADING_ENABLED=true AND an explicit in-app arming step (§14).
# Configuring this key alone does NOT enable live trading. Leave blank until
# you have completed paper validation.
# -----------------------------------------------------------------------------
TRADING212_LIVE_API_KEY=
TRADING212_LIVE_BASE_URL=https://live.trading212.com/api/v0

# Server-side master switch. Must be true before live mode can even be armed.
# Defaults to false. Never set true in development.
LIVE_TRADING_ENABLED=false

# Trading 212 publishes per-endpoint rate limits; these throttle our client.
TRADING212_MAX_REQUESTS_PER_MINUTE=30
TRADING212_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Market data — yfinance (no key required)
# Used for broad daily candles, long history, LSE-listed ETFs (§4).
# -----------------------------------------------------------------------------
YFINANCE_ENABLED=true
YFINANCE_MAX_CONCURRENCY=4
YFINANCE_BATCH_SIZE=50
YFINANCE_BACKOFF_BASE_SECONDS=2
YFINANCE_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Market data — Twelve Data (free Basic tier)
# Used for US intraday 15m signal candles only (§4).
#
# Budgets are operational limits, deliberately below the plan maximum so the
# reserve absorbs retries and reconciliation. Editable at runtime in admin
# settings; these are only the bootstrap defaults.
# -----------------------------------------------------------------------------
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_DAILY_MAX=800
TWELVE_DATA_DAILY_OPERATIONAL_LIMIT=720
TWELVE_DATA_DAILY_EMERGENCY_RESERVE=80
TWELVE_DATA_PER_MINUTE_MAX=8
TWELVE_DATA_PER_MINUTE_OPERATIONAL_LIMIT=7

# -----------------------------------------------------------------------------
# Market data — EODHD (free tier)
# Verification and gap-filling only. Never used to scan the full catalogue (§4).
# -----------------------------------------------------------------------------
EODHD_API_KEY=
EODHD_BASE_URL=https://eodhd.com/api
EODHD_DAILY_OPERATIONAL_LIMIT=18
EODHD_DAILY_EMERGENCY_RESERVE=2

# -----------------------------------------------------------------------------
# Data quality gates (§4)
#
# A candle older than STALE_CANDLE_MAX_AGE_MINUTES blocks signal generation for
# that instrument. Fail-closed is the intended behaviour (§17).
# -----------------------------------------------------------------------------
STALE_DAILY_CANDLE_MAX_AGE_HOURS=36
STALE_INTRADAY_CANDLE_MAX_AGE_MINUTES=45
REQUIRE_CLOSED_CANDLES=true
MIN_HISTORY_DAYS_FOR_SIGNAL=252

# -----------------------------------------------------------------------------
# Push notifications — VAPID (§13)
# Generate a keypair with:  pnpm --filter web exec web-push generate-vapid-keys
# The public key is safe to expose; the private key is not.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Observability (§18)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=trading-platform-api
